	private async Task SaveSchema()
	{
		await DataManager.SaveEditorValue(_schemaEditor, "schema");
	}

	private async Task HandleSchemaChanged()
	{
		if (_operation != SchemaOperations.GenerateSchema)
			_schemaEditorLanguage = await _schemaEditor.DetectLanguage(JsRuntime);
	}

	private async Task LoadSavedSchema()
	{
		await DataManager.LoadEditorValue(_schemaEditor, "schema");
	}

	private async Task SaveInstance()
	{
		await DataManager.SaveEditorValue(_instanceEditor, "schema-instance");
	}

	private async Task HandleInstanceChanged()
	{
		_instanceEditorLanguage = await _instanceEditor.DetectLanguage(JsRuntime);
	}

	private async Task LoadSavedInstance()
	{
		await DataManager.LoadEditorValue(_instanceEditor, "schema-instance");
	}

	private async Task LoadSavedSettings()
	{
		_options.OutputFormat = Enum.Parse<OutputFormat>(await DataManager.Get("schema-output-format") ?? "Hierarchical");
		_options.DialectId = await DataManager.Get("schema-dialect") ?? "https://json-schema.org/draft/2020-12/schema";
		_options.ValidateFormat = bool.Parse(await DataManager.Get("schema-validate-format") ?? "False");
		_options.IncludeDroppedAnnotations = bool.Parse(await DataManager.Get("schema-include-dropped-annotations") ?? "False");
		_options.AddAnnotationForUnknownKeywords = bool.Parse(await DataManager.Get("schema-add-annotation-unknown") ?? "False");
		_options.CultureCode = await DataManager.Get("error-culture") ?? "en-US";

		var operationStr = await DataManager.Get("schema-operation") ?? "Evaluate";
		Operation = Enum.Parse<SchemaOperations>(operationStr);
	}

	private async void SaveSettings()
	{
		await DataManager.Set("schema-operation", Operation.ToString());
		await DataManager.Set("schema-output-format", _options.OutputFormat.ToString());
		await DataManager.Set("schema-dialect", _options.DialectId);
		await DataManager.Set("schema-validate-format", _options.ValidateFormat.ToString());
		await DataManager.Set("schema-include-dropped-annotations", _options.IncludeDroppedAnnotations.ToString());
		await DataManager.Set("schema-add-annotation-unknown", _options.AddAnnotationForUnknownKeywords.ToString());
		await DataManager.Set("error-culture", _options.CultureCode);
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			ThemeService.OnThemeChanged += HandleThemeChanged;
			HandleThemeChanged();
			
			await JsRuntime.InvokeVoidAsync("initResizableSidebar");
			
            if (!_dialectsRegistered)
            {
	            Json.Schema.Data.MetaSchemas.Register();
	            Json.Schema.ArrayExt.MetaSchemas.Register();
	            Json.Schema.OpenApi.MetaSchemas.Register();
	            _dialectsRegistered = true;
            }

			await LoadSavedSchema();
			await LoadSavedInstance();
			_editorsInitialized = true;
			Operation = _operation;

			_baseCompilation = CSharpCompilation.Create("json-everything.TestAssembly",
				options: new CSharpCompilationOptions(OutputKind.DynamicallyLinkedLibrary),
				references: LoadAssemblyReferences());

			_schemaEditorLanguage = await _schemaEditor.DetectLanguage(JsRuntime);
			_instanceEditorLanguage = await _instanceEditor.DetectLanguage(JsRuntime);

			await _outputEditor.SetLanguageAsync("json", JsRuntime);
			await _outputEditor.UpdateOptions(new EditorUpdateOptions { TabSize = 2 });
			await _outputEditor.SetValue(string.Empty);
		}

		var t = _schemaEditorLanguage;
		_schemaEditorLanguage = "json";
		_schemaEditorLanguage = t;

		await base.OnAfterRenderAsync(firstRender);
	}

	private IEnumerable<MetadataReference> LoadAssemblyReferences() =>
		AppDomain.CurrentDomain.GetAssemblies()
			.Where(x => !x.IsDynamic)
			.Select(CreateReferenceFromRawMetadata)
			.Where(x => x != null)!;

	private MetadataReference? CreateReferenceFromRawMetadata(Assembly asm)
	{
		unsafe
		{
			if (!asm.TryGetRawMetadata(out byte* metadataPtr, out int metadataLength))
			{
				return null;
			}

			var metadata = ModuleMetadata.CreateFromMetadata((IntPtr)metadataPtr, metadataLength, () => GC.KeepAlive(asm));

			return AssemblyMetadata.Create(metadata).GetReference(display: asm.GetName().Name!);
		}
	}

	private void HandleThemeChanged()
	{
		var theme = ThemeService.MonacoTheme;
		_schemaEditor?.UpdateOptions(new EditorUpdateOptions { Theme = theme });
		_instanceEditor?.UpdateOptions(new EditorUpdateOptions { Theme = theme });
		_outputEditor?.UpdateOptions(new EditorUpdateOptions { Theme = theme });
		StateHasChanged();
	}

	private string GetImageUrl() =>
		ThemeService.IsDarkMode ? "img/json-schema.png" : "img/json-schema-light.png";



	public void Dispose()
	{
		ThemeService.OnThemeChanged -= HandleThemeChanged;
	}
}