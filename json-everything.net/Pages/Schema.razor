@page "/json-schema"
@implements IDisposable
@using Json.Schema.DataGeneration
@using Json.Schema
@using System.Text.Json
@using Json.Schema.Generation
@using JsonEverythingNet.Services
@using EditorOptions = JsonEverythingNet.Services.EditorOptions
@using System.Text.Encodings.Web
@using Microsoft.CodeAnalysis
@using Microsoft.CodeAnalysis.CSharp
@using System.Reflection
@using System.Reflection.Metadata
@using BlazorMonaco.Editor
@using Json.Schema.ArrayExt.Keywords
@using Json.Schema.Data.Keywords
@using Json.Schema.Generation.XmlComments
@using Json.Schema.OpenApi.Keywords
@using Yaml2JsonNode
@using System.Text
@using Json.Pointer


@inject DataManager DataManager;
@inject NavigationManager NavigationManager;
@inject IJSRuntime JsRuntime;
@inject EditorOptions EditorOptions;
@inject ThemeService ThemeService;
@inject SchemaLocalizationService SchemaLocalizationService;

<PageTitle>JSON Schema - json-everything.net</PageTitle>

<Banner Title="@IndexContent.AnnouncementTitle" Content="@IndexContent.MaintenanceFeeContent"></Banner>

<div class="schema-container">
	<div class="sidebar">
		<div class="sidebar-content">
			<div class="align-items-center hstack mx-2">
				<img src="@GetImageUrl()" height="70" width="70" class="me-3" />
				<h1 class="display-4">JSON Schema</h1>
			</div>
			<div class="align-items-center mx-3">
				<div>
					Constraints-based validation of JSON data. Learn more about
					<a href="https://json-schema.org" target="_blank">JSON Schema <ExternalLinkIcon /></a>
				</div>
			</div>
			<div class="align-items-center mt-1">
				@foreach (var library in _libraries)
				{
					<NugetLibrary Library="@library" />
				}
			</div>
			<hr />
			<EditForm Model="_options" class="vstack">
				<label class="my-2">
					What do you want to do?<br />
					<InputSelect @bind-Value="Operation" @bind-Value:after="SaveSettings" DisplayName="Spec version" class="form-control">
						@foreach (SchemaOperations operation in Enum.GetValues(typeof(SchemaOperations)))
						{
							<option value="@operation">@GetDescription(operation)</option>
						}
					</InputSelect>
				</label>
				<div class="vstack @EvaluationOptionsVisibility">
					<label class="my-2">
						Spec Version (<span class="small"><span class="font-monospace">$schema</span> will override</span>)
						<span class="tooltip-icon">
							ⓘ
							<span class="tooltip-text">
								<MarkdownSpan Content="@HelpContent.SchemaVersion"></MarkdownSpan>
							</span>
						</span>
						<br />
						<InputSelect @bind-Value="_options.DialectId" @bind-Value:after="SaveSettings" DisplayName="Spec version" class="form-control">
							@foreach (var dialect in _dialects)
							{
								<option value="@dialect.Id!.OriginalString">@GetDescription(dialect)</option>
							}
						</InputSelect>
					</label>
					<label class="my-2">
						Output format
						<span class="tooltip-icon">
							ⓘ
							<span class="tooltip-text">
								<MarkdownSpan Content="@HelpContent.SchemaOutputFormat"></MarkdownSpan>
							</span>
						</span>
						<br />
						<InputSelect @bind-Value="_options.OutputFormat" @bind-Value:after="SaveSettings" DisplayName="Output format" class="form-control">
							@foreach (var format in Enum.GetValues(typeof(OutputFormat)))
							{
								<option value="@format">@format</option>
							}
						</InputSelect>
					</label>
                    <label class="my-2">
                        Error message language
                        <span class="tooltip-icon">
                            ⓘ
                            <span class="tooltip-text">
                                Select the language for validation error messages.
                            </span>
                        </span>
                        <br />
                        <InputSelect @bind-Value="_options.CultureCode" @bind-Value:after="SaveSettings" DisplayName="Language" class="form-control">
                            @foreach (var culture in _cultures)
                            {
                                <option value="@culture.Key">@culture.Value</option>
                            }
                        </InputSelect>
                    </label>
                    <label class="my-2">
						<InputCheckbox @bind-Value="_options.IncludeDroppedAnnotations" @bind-Value:after="SaveSettings" DisplayName="Preserve dropped annotations" />
						Preserve dropped annotations
						<span class="tooltip-icon">
							ⓘ
							<span class="tooltip-text">
								<MarkdownSpan Content="@HelpContent.SchemaDroppedAnnotations"></MarkdownSpan>
							</span>
						</span>
					</label>
					<label class="my-2">
						<InputCheckbox @bind-Value="_options.AddAnnotationForUnknownKeywords" @bind-Value:after="SaveSettings" DisplayName="Unknown keywords annotation" />
						Unknown keywords annotation
						<span class="tooltip-icon">
							ⓘ
							<span class="tooltip-text">
								<MarkdownSpan Content="@HelpContent.SchemaUnknownKeywordsAnnotation"></MarkdownSpan>
							</span>
						</span>
					</label>
					<label class="my-2">
						<InputCheckbox @bind-Value="_options.ValidateFormat" @bind-Value:after="SaveSettings" DisplayName="Validate format" />
						Validate <span class="font-monospace">format</span>
						<span class="tooltip-icon">
							ⓘ
							<span class="tooltip-text">
								<MarkdownSpan Content="@HelpContent.SchemaValidateFormat"></MarkdownSpan>
							</span>
						</span>
					</label>
				</div>
				<button class="btn btn-primary mt-2" @onclick="Run">Run</button>
			</EditForm>
			<hr />
			<MarkdownSpan Content="@HelpSummary"></MarkdownSpan>
		</div>
	</div>
	<div class="resize-handle"></div>
	<div class="main-content">
		<div class="editor-grid @(Operation != SchemaOperations.Evaluate ? "no-output-mode" : string.Empty)">
			<div class="top-editors-row" id="top-editors-row">
				<div class="editor-cell left-editor" id="left-editor-cell">
					<div class="editor-container">
						<span class="editor-lang-@_schemaEditorLanguage">@GetLanguageText(_schemaEditorLanguage)</span>
						<StandaloneCodeEditor @ref="_schemaEditor" Id="editor-schema" ConstructionOptions="BasicOptions"
						CssClass="h-100" OnDidChangeModelContent="HandleSchemaChanged" />
					</div>
				</div>
				<div class="resize-handle" id="vertical-resize-handle"></div>
				<div class="editor-cell right-editor" id="right-editor-cell">
					<div class="editor-container">
						<span class="editor-lang-@_instanceEditorLanguage">@GetLanguageText(_instanceEditorLanguage)</span>
						<StandaloneCodeEditor @ref="_instanceEditor" Id="editor-instance" ConstructionOptions="BasicOptions"
						CssClass="h-100" OnDidChangeModelContent="HandleInstanceChanged" />
					</div>
				</div>
			</div>
			<div class="resize-handle horizontal" id="horizontal-resize-handle"></div>
			<div class="editor-cell output-cell" id="bottom-editor-cell">
				<div class="editor-container">
					<StandaloneCodeEditor @ref="_outputEditor" Id="editor-output" ConstructionOptions="ReadOnlyOptions"
					CssClass="h-100" />
				</div>
			</div>
		</div>
	</div>
</div>

@code {
    #pragma warning disable CS8618
    private StandaloneCodeEditor _schemaEditor;
    private string _schemaEditorLanguage;
    private StandaloneCodeEditor _instanceEditor;
    private string _instanceEditorLanguage;
    private StandaloneCodeEditor _outputEditor;
    private static bool _dialectsRegistered;

    private readonly SchemaOptionsModel _options = new();

    private readonly List<LibraryVersion> _libraries =
	[
        LibraryVersion.GetFor<JsonSchema>(),
		LibraryVersion.GetFor<DataKeyword>(),
		LibraryVersion.GetFor<UniqueKeysKeyword>(),
		LibraryVersion.GetFor<DiscriminatorKeyword>(),
		LibraryVersion.GetFor<ISchemaRefiner>(),
		LibraryVersion.GetFor<Bound>()
    ];

	private Compilation _baseCompilation;

    private readonly List<Dialect> _dialects =
    [
        Dialect.Draft06,
	    Dialect.Draft07,
	    Dialect.Draft201909,
	    Dialect.Draft202012,
	    Dialect.V1_2026,
	    Json.Schema.ArrayExt.Dialect.ArrayExt_202012,
	    Json.Schema.Data.Dialect.Data_202012,
	    Json.Schema.OpenApi.Dialect.OpenApi_31,
    ];

    private readonly Dictionary<string, string> _cultures = new()
	{
		{ "en-US", "English (default)" },
		{ "de", "Deutsch (German)" },
		{ "es", "Español (Spanish)" },
		{ "it", "Italiano (Italian)" },
		{ "ko", "한국어 (Korean)" },
		{ "nb-NO", "Norsk (Norwegian)" },
		{ "pl-PL", "Polski (Polish)" },
		{ "pt", "Português (Portuguese)" },
		{ "ru", "Русский (Russian)" },
		{ "sv-SE", "Svenska (Swedish)" },
		{ "tr-TR", "Türkçe (Turkish)" }
	};

    private IEnumerable<MetadataReference> _references;
    private SchemaOperations _operation = SchemaOperations.Evaluate;
	private bool _editorsInitialized;

#pragma warning restore CS8618

    public enum SchemaOperations
    {
        Evaluate,
        GenerateSchema,
		GenerateData
    }

    private class SchemaOptionsModel
    {
        public OutputFormat OutputFormat { get; set; } = OutputFormat.Hierarchical;
        public Dialect Dialect { get; set; } = Dialect.Draft202012;

        public string DialectId
        {
            get => Dialect.Id!.OriginalString;
            set
            {
                Dialect = value switch
                {
                    "http://json-schema.org/draft-06/schema#" => Dialect.Draft06,
                    "http://json-schema.org/draft-07/schema#" => Dialect.Draft07,
                    "https://json-schema.org/draft/2019-09/schema" => Dialect.Draft201909,
                    "https://json-schema.org/draft/2020-12/schema" => Dialect.Draft202012,
                    "https://json-schema.org/v1/2026" => Dialect.V1_2026,
                    "https://json-everything.net/meta/array-ext" => Json.Schema.ArrayExt.Dialect.ArrayExt_202012,
                    "https://json-everything.net/meta/data-2023" => Json.Schema.Data.Dialect.Data_202012,
                    "https://spec.openapis.org/oas/3.1/dialect/base" => Json.Schema.OpenApi.Dialect.OpenApi_31,
                    _ => Dialect.Draft202012
                };
            }
        }

        public bool ValidateFormat { get; set; }
        public bool IncludeDroppedAnnotations { get; set; }
        public bool AddAnnotationForUnknownKeywords { get; set; }
        public string CultureCode { get; set; } = "en-US";

		public BuildOptions ToBuildOptions() => new()
		{
			SchemaRegistry = new(),
			Dialect = Dialect
		};

		public EvaluationOptions ToEvaluationOptions() => new()
		{
			OutputFormat = OutputFormat,
			RequireFormatValidation = ValidateFormat,
			PreserveDroppedAnnotations = IncludeDroppedAnnotations,
			AddAnnotationForUnknownKeywords = AddAnnotationForUnknownKeywords
		};
	}

	public SchemaOperations Operation
	{
		get => _operation;
		set
		{
			_operation = value;

			if (!_editorsInitialized)
			{
				ApplyOperationDisplayState();
				return;
			}

			switch (value)
			{
				case SchemaOperations.GenerateSchema:
					ConfigureForSchemaGen();
					break;
				case SchemaOperations.GenerateData:
					ConfigureForDataGen();
					break;
				case SchemaOperations.Evaluate:
				default:
					ConfigureForEvaluation();
					break;
			}
		}
	}

	private void ApplyOperationDisplayState()
	{
		switch (_operation)
		{
			case SchemaOperations.GenerateSchema:
				SchemaEditorLabel = "Classes (C#)";
				HelpSummary = HelpContent.SchemaGenerateSchema;
				EvaluationOptionsVisibility = "d-none";
				break;
			case SchemaOperations.GenerateData:
				SchemaEditorLabel = "Schema";
				HelpSummary = HelpContent.SchemaGenerateData;
				EvaluationOptionsVisibility = "d-none";
				break;
			case SchemaOperations.Evaluate:
			default:
				SchemaEditorLabel = "Schema";
				HelpSummary = HelpContent.SchemaEvaluate;
				EvaluationOptionsVisibility = "";
				break;
		}
	}

	private string HelpSummary { get; set; } = HelpContent.SchemaEvaluate;
	private string SchemaEditorLabel { get; set; } = "Schema (supports JSON & YAML)";
	private string EvaluationOptionsVisibility { get; set; } = "visible";

	private StandaloneEditorConstructionOptions BasicOptions(StandaloneCodeEditor _) => EditorOptions.Basic();
	private StandaloneEditorConstructionOptions ReadOnlyOptions(StandaloneCodeEditor _) => EditorOptions.Readonly();

	protected override async Task OnInitializedAsync()
	{
		await LoadSavedSettings();
		await base.OnInitializedAsync();
	}

	private static string GetLanguageText(string langKey) => langKey switch
	{
		"csharp" => "c#",
		_ => langKey
	};

	private static string GetDescription(Dialect dialect) => dialect.Id!.OriginalString switch
	{
		"http://json-schema.org/draft-06/schema#" => "Draft 6",
		"http://json-schema.org/draft-07/schema#" => "Draft 7",
		"https://json-schema.org/draft/2019-09/schema" => "Draft 2019-09",
		"https://json-schema.org/draft/2020-12/schema" => "Draft 2020-12",
		"https://json-schema.org/v1/2026" => "V1 2026 (preview)",
		"https://json-everything.net/meta/array-ext" => "2020-12 + Array Extensions Vocabulary",
        "https://json-everything.net/meta/data-2023" => "2020-12 + Data Vocabulary",
		"https://spec.openapis.org/oas/3.1/dialect/base" => "OpenAPI 3.1",
		_ => dialect.Id!.OriginalString
	};

	private static string GetDescription(SchemaOperations operation) => operation switch
	{
		SchemaOperations.Evaluate => "Evaluate JSON",
		SchemaOperations.GenerateSchema => "Generate a Schema",
		SchemaOperations.GenerateData => "Generate Data",
		_ => "Evaluate JSON"
	};

	private void ConfigureForEvaluation()
	{
		_schemaEditor.UpdateOptions(new EditorUpdateOptions { TabSize = 2 });
		Task.Run(async () =>
		{
			var language = await _schemaEditor.DetectLanguage(JsRuntime);
			await _schemaEditor.SetLanguageAsync(language, JsRuntime);
			_schemaEditorLanguage = language;
		});
		_instanceEditor.UpdateOptions(new EditorUpdateOptions { ReadOnly = false });

		SchemaEditorLabel = "Schema";

		HelpSummary = HelpContent.SchemaEvaluate;

		EvaluationOptionsVisibility = "";
	}

	private void ConfigureForSchemaGen()
	{
		_schemaEditor.SetLanguage("csharp", JsRuntime);
		_schemaEditorLanguage = "csharp";
		_schemaEditor.UpdateOptions(new EditorUpdateOptions { TabSize = 4 });
		_instanceEditor.UpdateOptions(new EditorUpdateOptions { ReadOnly = true });

		SchemaEditorLabel = "Classes (C#)";

		HelpSummary = HelpContent.SchemaGenerateSchema;

		EvaluationOptionsVisibility = "d-none";
	}

	private void ConfigureForDataGen()
	{
		_schemaEditor.UpdateOptions(new EditorUpdateOptions { TabSize = 2 });
		Task.Run(async () =>
		{
			_schemaEditorLanguage = await _schemaEditor.DetectLanguage(JsRuntime);
		});
		_instanceEditor.UpdateOptions(new EditorUpdateOptions { ReadOnly = true });

		SchemaEditorLabel = "Schema";

		HelpSummary = HelpContent.SchemaGenerateData;

		EvaluationOptionsVisibility = "d-none";
	}

	private async Task Run()
	{
		SaveSettings();
		await SaveSchema();
		await SaveInstance();

		switch (Operation)
		{
			case SchemaOperations.Evaluate:
				await Validate();
				break;
			case SchemaOperations.GenerateSchema:
				await GenerateSchema();
				break;
			case SchemaOperations.GenerateData:
				await GenerateData();
				break;
			default:
				throw new ArgumentOutOfRangeException();
		}
	}

	private async Task Validate()
	{
		await SchemaLocalizationService.SetCultureAsync(_options.CultureCode);
        await DataManager.Set("error-culture", _options.CultureCode);
        await _outputEditor.SetLanguageAsync("json", JsRuntime);
		await _outputEditor.SetValue(string.Empty);

		JsonSchema schema;
		try
		{
			var text = await _schemaEditor.GetValue();
			var schemaJson = YamlSerializer.Parse(text).Single().ToJsonElement();
			schema = JsonSchema.Build(schemaJson, _options.ToBuildOptions());
		}
		catch (Exception e)
		{
			await _outputEditor.SetLanguageAsync("text", JsRuntime);
			await _outputEditor.SetValue($"Schema is invalid\n\n{e.Message}");
			return;
		}
		JsonElement instance;
		try
		{
			instance = YamlSerializer.Parse(await _instanceEditor.GetValue()).Single().ToJsonElement();
		}
		catch (Exception e)
		{
			await _outputEditor.SetLanguageAsync("text", JsRuntime);
			await _outputEditor.SetValue($"Instance is invalid\n\n{e.Message}");
			return;
		}

		try
		{
			var results = schema.Evaluate(instance, _options.ToEvaluationOptions());

			var serializerOptions = new JsonSerializerOptions
			{
				WriteIndented = true,
				Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
			};
			var resultText = JsonSerializer.Serialize(results, serializerOptions);

			await _outputEditor.SetValue(resultText);
		}
		catch (Exception e)
		{
			await _outputEditor.SetLanguageAsync("text", JsRuntime);
			await _outputEditor.SetValue(e.Message);
		}
	}

	private async Task GenerateData()
	{
		await _outputEditor.SetLanguageAsync("json", JsRuntime);
		await _outputEditor.SetValue(string.Empty);

		JsonSchema schema;
		try
		{
			var schemaJson = YamlSerializer.Parse(await _schemaEditor.GetValue()).Single().ToJsonElement();
			schema = JsonSchema.Build(schemaJson, _options.ToBuildOptions());
		}
		catch (Exception e)
		{
			await _outputEditor.SetLanguageAsync("text", JsRuntime);
			await _outputEditor.SetValue($"Schema is invalid\n\n{e.Message}");
			return;
		}

		var generationResults = schema.GenerateData();

		if (generationResults.IsSuccess)
		{
			var instance = JsonSerializer.Serialize(generationResults.Result, new JsonSerializerOptions { WriteIndented = true });
			await _instanceEditor.SetValue(instance);
			await _instanceEditor.SetLanguageAsync("json", JsRuntime);
			await SaveInstance();
		}
		else
		{
			var errorText = FormatGenerationError(generationResults);
			await _instanceEditor.SetValue(errorText);
			await _instanceEditor.SetLanguageAsync("text", JsRuntime);
		}
	}

	private static string FormatGenerationError(GenerationResult result)
	{
		const int maxLeafReasons = 7;
		const int maxVisitedNodes = 2000;

		var leafReasons = new List<(string? Path, string Message, IReadOnlyList<JsonPointer>? SchemaLocations)>();
		var seenKeys = new HashSet<string>();

		void AddLeafReason(string? path, string message, IReadOnlyList<JsonPointer>? schemaLocations)
		{
			if (seenKeys.Add($"{path}|{message}"))
				leafReasons.Add((path, message, schemaLocations));
		}

		var stack = new Stack<(GenerationResult Result, string? Path)>();
		stack.Push((result, null));

		var visited = 0;
		while (stack.Count > 0 && visited < maxVisitedNodes)
		{
			visited++;
			var (current, parentPath) = stack.Pop();

			var path = current.Location.HasValue
				? (parentPath != null ? parentPath + current.Location.Value : current.Location.Value.ToString())
				: parentPath;

			if (current.ErrorMessage != null)
			{
				AddLeafReason(path, current.ErrorMessage, current.SchemaLocations);
				continue;
			}

			if (current.InnerResults == null)
			{
				AddLeafReason(path, "Data generation failed.", null);
				continue;
			}

			foreach (var inner in current.InnerResults.Reverse())
				stack.Push((inner, path));
		}

		if (leafReasons.Count == 0)
			return "Data generation failed.";

		var displayed = leafReasons.Take(maxLeafReasons).ToList();
		var sb = new StringBuilder();
		for (var i = 0; i < displayed.Count; i++)
		{
			var (path, message, schemaLocations) = displayed[i];
			if (i > 0) sb.AppendLine();
			sb.Append($"{i + 1}.");
			if (path != null) sb.AppendLine($" at instance {path}");
			else sb.AppendLine(" at instance root");
			sb.AppendLine($"   {message}");
			if (schemaLocations != null && schemaLocations.Count > 0)
			{
				sb.AppendLine($"   at schema {schemaLocations[0]}");
				for (var j = 1; j < schemaLocations.Count; j++)
					sb.AppendLine($"             {schemaLocations[j]}");
			}
		}

		if (leafReasons.Count > maxLeafReasons)
			sb.AppendLine($"\n...and {leafReasons.Count - maxLeafReasons} more reason(s)");

		return sb.ToString().TrimEnd();
	}

#pragma warning disable CS0618 // Type or member is obsolete
	private async Task GenerateSchema()
	{
		await _instanceEditor.SetLanguageAsync("json", JsRuntime);
		await _instanceEditor.SetValue(string.Empty);

		Assembly? assembly = null;
		try
		{
			var source = await _schemaEditor.GetValue();

			var fullSource = $@"
using System;
using System.Collections.Generic;
using System.Text.Json;
using System.Text.Json.Nodes;
using System.Text.Json.Serialization;
using Json.Schema;
using Json.Schema.Generation;

namespace JsonEverythingTemp;

{source}
";

			var syntaxTree = CSharpSyntaxTree.ParseText(fullSource);
			var assemblyPath = System.IO.Path.ChangeExtension(System.IO.Path.GetTempFileName(), "dll");

			var compilation = _baseCompilation
				.AddSyntaxTrees(syntaxTree);

			using var dllStream = new MemoryStream();
			using var pdbStream = new MemoryStream();
			using var xmlStream = new MemoryStream();
			var emitResult = compilation.Emit(dllStream, pdbStream, xmlStream);
			if (!emitResult.Success)
			{
				var errors = string.Join("\n", emitResult.Diagnostics
					.Where(x => x.Severity == DiagnosticSeverity.Error)
					.Select((x, i) => $"{i+1}. {x.GetMessage()}"));
				await _instanceEditor.SetLanguageAsync("text", JsRuntime);
				await _instanceEditor.SetValue($"Compilation error:\n\n{errors}");
				return;
			}

			assembly = Assembly.Load(dllStream.ToArray());
			var type = assembly.DefinedTypes.First(x => x.Namespace == "JsonEverythingTemp");

			xmlStream.Position = 0;
			using var reader = new StreamReader(xmlStream);
			var xmlContent = await reader.ReadToEndAsync();
			DocXmlReader.ExplicitlyAddAssemblyXml(assembly, xmlContent);


			Console.WriteLine($"Generating schema for type '{type.Name}'");
			JsonSchema schema = new JsonSchemaBuilder().FromType(type);

			await _instanceEditor.SetValue(JsonSerializer.Serialize(schema, new JsonSerializerOptions { WriteIndented = true }));
			await SaveInstance();
		}
		catch (Exception e)
		{
			await _instanceEditor.SetLanguageAsync("text", JsRuntime);
			await _instanceEditor.SetValue(e.Message);
		}
		finally
		{
			if (assembly is not null)
				DocXmlReader.ExplictlyRemoveAssemblyXml(assembly);
		}
	}
#pragma warning restore CS0618 // Type or member is obsolete

